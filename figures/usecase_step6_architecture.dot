digraph usecase_step6_architecture {
  graph [rankdir="TB", splines="ortho", pad="0.06", margin="0.02", nodesep="0.18", ranksep="0.32", bgcolor="white", labelloc="t", labeljust="c", label="Step 6: Synchronized Analysis Architecture", fontname="Helvetica-Bold", fontsize="11"];
  node [shape="box", style="rounded,filled", color="#3A3A3A", penwidth="0.9", fillcolor="white", fontname="Helvetica", fontsize="9", margin="0.10,0.06", width="1.0", height="0.32"];
  edge [color="#4A4A4A", penwidth="0.8", arrowsize="0.55"];

  subgraph cluster_1 {
    graph [label="ECS Core", color="#8C8C8C", penwidth="0.7", style="rounded,dashed,filled", fontname="Helvetica-Bold", fontsize="9", margin="10", fillcolor="#FAFAFA"];
    "adaption" [label="Adaptation Unit"];
    "consumer" [label="Consumer"];
    "ecs_hw" [label="ECS Hardware"];
    "ecs_sw" [label="ECS Software"];
  }

  subgraph cluster_2 {
    graph [label="Atmosphere", color="#8C8C8C", penwidth="0.7", style="rounded,dashed,filled", fontname="Helvetica-Bold", fontsize="9", margin="10", fillcolor="#F2F2F2"];
    "atmos" [label="Atmosphere"];
  }

  subgraph cluster_3 {
    graph [label="Additional Couplings", color="#8C8C8C", penwidth="0.7", style="rounded,dashed,filled", fontname="Helvetica-Bold", fontsize="9", margin="10", fillcolor="#ECECEC"];
    "fuel" [label="Fuel System"];
    "interface_model" [label="Aero Interface"];
    "valve_model" [label="Valve Model"];
  }

  "adaption" -> "ecs_sw";
  "atmos" -> "consumer";
  "atmos" -> "ecs_hw";
  "atmos" -> "fuel";
  "consumer" -> "fuel";
  "ecs_hw" -> "adaption";
  "ecs_hw" -> "consumer";
  "ecs_sw" -> "ecs_hw";
  "fuel" -> "ecs_hw";
  "fuel" -> "interface_model";
  "fuel" -> "valve_model";
  "interface_model" -> "valve_model";
  "valve_model" -> "interface_model";
}
